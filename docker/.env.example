# Overrides for docker/docker-compose.yml build args.
# Copy to docker/.env and fill in your values before running compose.

VITE_API_BASE_URL=http://localhost:8000
VITE_COGNITO_DOMAIN=https://YOUR_DOMAIN.auth.YOUR_REGION.amazoncognito.com
VITE_COGNITO_CLIENT_ID=YOUR_COGNITO_APP_CLIENT_ID
VITE_COGNITO_REDIRECT_URI=http://localhost:8080/callback
VITE_COGNITO_SCOPE=email+openid+phone

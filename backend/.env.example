APP_NAME=NZ Address Checker API
APP_ENV=dev
FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated list for multi-origin local/staging support.
FRONTEND_ORIGINS=

# Cognito / JWT validation
JWT_ISSUER=https://cognito-idp.ap-southeast-2.amazonaws.com/ap-southeast-2_example
JWT_AUDIENCE=example_client_id
JWKS_URL=https://cognito-idp.ap-southeast-2.amazonaws.com/ap-southeast-2_example/.well-known/jwks.json

# Cognito group required for access to the validation page (must match exactly)
ALLOWED_GROUP=AddressValidators

# NZ Post integration — base URL is https://api.nzpost.co.nz (path appended by service)
NZPOST_API_URL=https://api.nzpost.co.nz
NZPOST_API_KEY=replace-me
# Valid range: 1–30 seconds
NZPOST_TIMEOUT_SECONDS=3
# Set to false in production to use real NZ Post API
NZPOST_MOCK=true

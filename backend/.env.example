APP_NAME=NZ Address Checker API
APP_ENV=dev

# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGINS=http://localhost:5173

# ── AWS Cognito JWT validation ─────────────────────────────────────────────
# Found in: AWS Console → Cognito → User Pools → your pool → Overview
JWT_ISSUER=https://cognito-idp.YOUR_REGION.amazonaws.com/YOUR_USER_POOL_ID
JWT_AUDIENCE=YOUR_COGNITO_APP_CLIENT_ID
JWKS_URL=https://cognito-idp.YOUR_REGION.amazonaws.com/YOUR_USER_POOL_ID/.well-known/jwks.json

# ── NZ Post API ────────────────────────────────────────────────────────────
# Set NZPOST_MOCK=false and fill in real values when connecting to NZ Post.
NZPOST_MOCK=true
NZPOST_API_URL=https://api.nzpost.co.nz/REPLACE_WITH_ENDPOINT
NZPOST_API_KEY=REPLACE_WITH_YOUR_NZPOST_API_KEY
NZPOST_TIMEOUT_SECONDS=3

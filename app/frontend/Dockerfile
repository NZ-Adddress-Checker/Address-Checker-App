FROM node:18 AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

ARG REACT_APP_API_URL
ARG REACT_APP_COGNITO_AUTHORITY
ARG REACT_APP_COGNITO_DOMAIN
ARG REACT_APP_COGNITO_CLIENT_ID
ARG REACT_APP_REDIRECT_URI
ARG REACT_APP_LOGOUT_URI
ENV REACT_APP_API_URL=$REACT_APP_API_URL \
    REACT_APP_COGNITO_AUTHORITY=$REACT_APP_COGNITO_AUTHORITY \
    REACT_APP_COGNITO_DOMAIN=$REACT_APP_COGNITO_DOMAIN \
    REACT_APP_COGNITO_CLIENT_ID=$REACT_APP_COGNITO_CLIENT_ID \
    REACT_APP_REDIRECT_URI=$REACT_APP_REDIRECT_URI \
    REACT_APP_LOGOUT_URI=$REACT_APP_LOGOUT_URI

RUN npm run build

FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]

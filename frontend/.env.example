# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# ── AWS Cognito ────────────────────────────────────────────────────────────
# Found in: AWS Console → Cognito → User Pools → your pool → App clients
VITE_COGNITO_DOMAIN=https://YOUR_DOMAIN.auth.YOUR_REGION.amazoncognito.com
VITE_COGNITO_CLIENT_ID=YOUR_COGNITO_APP_CLIENT_ID
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback
VITE_COGNITO_SCOPE=email+openid+phone
